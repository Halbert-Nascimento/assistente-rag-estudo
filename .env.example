# Copie este arquivo para .env e ajuste se necessario
# (o .env real nao e versionado no git)

LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1

# Local:  http://localhost:11434
# Docker: http://ollama:11434 (definido no docker-compose.yml)
OLLAMA_BASE_URL=http://localhost:11434

DOCS_DIR=docs

# --- Recuperacao em dois estagios: recall + rerank (FEAT-009) ---
# Deixe em branco para usar os defaults do codigo. So mexa se precisar calibrar.

# Modelo cross-encoder de reranking (baixado 1x e cacheado).
# Mais leve/rapido: cross-encoder/mmarco-mMiniLMv2-L12-H384-v1 (default)
# Mais qualidade (e mais pesado): BAAI/bge-reranker-base
# RERANK_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1

# Porta de relevancia do reranker (0..1). Abaixo disso o chunk e descartado;
# se nenhum passar, a pergunta e recusada sem chamar o LLM. Calibre com:
#   python eval/eval.py --full
# RERANK_MIN_SCORE=0.30

# Quantos candidatos o recall traz (rede ampla) e quantos vao ao LLM apos rerank.
# RAG_RECALL_K=20
# RAG_TOP_N=4
